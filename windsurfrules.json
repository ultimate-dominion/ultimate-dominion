{
  "project": {
    "name": "Ultimate Dominion",
    "description": "A medieval fantasy trading card game with blockchain integration",
    "repository": "ultimate-dominion/ultimate-dominion"
  },
  "documentation": {
    "style": {
      "language": "simple and narrative",
      "technical_terms": "must be explained with real-world analogies",
      "format": {
        "primary": "markdown with ASCII diagrams",
        "rules": [
          "Use paragraph form for all explanations",
          "No bullet points or numbered lists allowed",
          "Every diagram must be explained in narrative form",
          "Use real-world analogies to explain technical concepts",
          "Keep language simple and accessible"
        ]
      },
      "required_sections": [
        "overview",
        "how it works",
        "examples",
        "technical details"
      ]
    },
    "maintenance_rules": {
      "code_changes": {
        "description": "Rules for updating documentation when code changes",
        "rules": [
          {
            "trigger": "API Changes",
            "required_updates": [
              "backend_structure.md: Update API endpoints and examples",
              "technical_architecture.md: Update API flow diagrams if needed",
              "implementation_plan.md: Update deployment steps if needed",
              "frontend_guidelines.md: Update API integration examples"
            ]
          },
          {
            "trigger": "Frontend Changes",
            "required_updates": [
              "frontend_guidelines.md: Update component documentation",
              "app_flow_document.md: Update user journey if changed",
              "technical_architecture.md: Update frontend architecture if needed"
            ]
          },
          {
            "trigger": "Smart Contract Changes",
            "required_updates": [
              "smart_contracts.md: Update contract documentation",
              "technical_architecture.md: Update blockchain integration if needed",
              "implementation_plan.md: Update deployment steps"
            ]
          },
          {
            "trigger": "Infrastructure Changes",
            "required_updates": [
              "technical_architecture.md: Update architecture diagrams",
              "implementation_plan.md: Update deployment process",
              "backend_structure.md: Update environment configurations"
            ]
          }
        ]
      },
      "review_process": {
        "description": "Documentation review requirements",
        "steps": [
          {
            "when": "Before PR",
            "actions": [
              "Use documentation_review_checklist.md",
              "Update all affected documents",
              "Cross-reference related documents",
              "Verify diagrams and examples"
            ]
          },
          {
            "when": "During PR Review",
            "actions": [
              "Reviewer must verify documentation updates",
              "Check cross-document consistency",
              "Validate technical accuracy",
              "Ensure style guidelines followed"
            ]
          },
          {
            "when": "After Merge",
            "actions": [
              "Verify documentation deployed correctly",
              "Update version numbers if needed",
              "Check all links still work",
              "Update change logs"
            ]
          }
        ]
      },
      "verification_checklist": {
        "description": "Required checks for documentation updates",
        "checks": [
          {
            "category": "Content",
            "items": [
              "Technical accuracy",
              "Cross-document consistency",
              "Style guideline compliance",
              "Diagram accuracy"
            ]
          },
          {
            "category": "Completeness",
            "items": [
              "All affected documents updated",
              "Cross-references maintained",
              "Examples updated",
              "Version numbers updated"
            ]
          },
          {
            "category": "Quality",
            "items": [
              "Narrative style maintained",
              "Real-world analogies used",
              "Clear and accessible language",
              "Proper formatting"
            ]
          }
        ]
      }
    },
    "required_files": [
      {
        "name": "frontend_guidelines.md",
        "contents": [
          "design philosophy",
          "color palette",
          "typography",
          "icons",
          "component design",
          "layout guidelines",
          "animations",
          "accessibility",
          "performance"
        ]
      },
      {
        "name": "backend_structure.md",
        "contents": [
          "system architecture",
          "api routes",
          "data flow",
          "environments",
          "deployment",
          "monitoring",
          "performance",
          "security"
        ]
      },
      {
        "name": "technical_architecture.md",
        "contents": [
          "system overview",
          "component interactions",
          "data models",
          "security measures",
          "scalability approach"
        ]
      },
      {
        "name": "app_flow_document.md",
        "contents": [
          "user journeys",
          "game mechanics",
          "screen flows",
          "interaction patterns"
        ]
      }
    ]
  },
  "development": {
    "environments": {
      "local": {
        "frontend": "http://localhost:5173",
        "api": "http://localhost:8080",
        "purpose": "development and testing"
      },
      "staging": {
        "frontend": "ultimate-dominion-staging.vercel.app",
        "api": "ultimate-dominion-api.onrender.com",
        "purpose": "pre-production testing"
      },
      "production": {
        "frontend": "ultimate-dominion.vercel.app",
        "api": "ultimate-dominion-api.onrender.com",
        "purpose": "live deployment"
      }
    },
    "code_style": {
      "frontend": {
        "framework": "React with TypeScript",
        "state_management": "Zustand",
        "styling": "Tailwind CSS",
        "component_structure": "atomic design"
      },
      "backend": {
        "framework": "Express.js",
        "deployment": "Vercel Serverless",
        "blockchain": "MUD framework",
        "storage": "IPFS via Pinata"
      }
    },
    "deployment_rules": {
      "pre_deploy_checks": [
        "run all tests",
        "check environment variables",
        "verify smart contracts",
        "test API endpoints",
        "check frontend builds",
        "verify IPFS connections"
      ],
      "post_deploy_checks": [
        "monitor error rates",
        "check response times",
        "verify blockchain state",
        "test critical user flows",
        "monitor resource usage"
      ]
    },
    "security_rules": {
      "required": [
        "validate all requests",
        "authenticate users via wallet",
        "authorize actions",
        "sanitize inputs",
        "rate limit requests",
        "verify blockchain transactions"
      ],
      "environment_variables": {
        "required": [
          "PINATA_JWT",
          "PRIVATE_KEY",
          "WORLD_ADDRESS",
          "INITIAL_BLOCK_NUMBER",
          "RPC_URL"
        ],
        "optional": [
          "DEBUG_MODE",
          "RATE_LIMIT_WINDOW",
          "CACHE_TTL"
        ]
      }
    },
    "performance_targets": {
      "api_response_time": "< 200ms",
      "page_load_time": "< 2s",
      "time_to_interactive": "< 3s",
      "blockchain_confirmation": "< 5s"
    }
  },
  "architecture": {
    "verification_rules": [
      {
        "name": "architectural_consistency",
        "description": "Before making any architectural decisions or documentation updates",
        "checks": [
          "Review technical_architecture.md as the source of truth",
          "Cross-reference with existing implementation",
          "Question any inconsistencies with current architecture",
          "Validate assumptions about deployment platforms",
          "Verify technology stack matches documentation"
        ]
      },
      {
        "name": "implementation_validation",
        "description": "Before implementing new features or making changes",
        "checks": [
          "Confirm deployment strategy matches Vercel Edge Functions architecture",
          "Verify all API endpoints are designed for serverless execution",
          "Ensure changes align with MUD Framework patterns",
          "Check that environment configurations match deployment platform"
        ]
      }
    ],
    "deployment_rules": {
      "frontend": {
        "platform": "Vercel",
        "type": "Static Application",
        "build_output": "packages/client/dist"
      },
      "backend": {
        "platform": "Vercel",
        "type": "Edge Functions",
        "location": "packages/api/src/functions"
      },
      "blockchain": {
        "framework": "MUD",
        "indexer": "MUD Indexer",
        "deployment": "packages/contracts"
      }
    }
  },
  "implementation": {
    "verification_steps": [
      {
        "name": "pre_implementation",
        "required_checks": [
          "Review technical_architecture.md",
          "Verify deployment platform requirements",
          "Check existing patterns in codebase",
          "Validate against architecture rules"
        ]
      },
      {
        "name": "during_implementation",
        "required_checks": [
          "Follow established patterns",
          "Maintain serverless design principles",
          "Keep deployment platform constraints in mind",
          "Document any architectural decisions"
        ]
      },
      {
        "name": "post_implementation",
        "required_checks": [
          "Verify changes match architecture",
          "Update documentation if needed",
          "Test in proper deployment environment",
          "Validate serverless execution"
        ]
      }
    ]
  },
  "git": {
    "branch_naming": {
      "feature": "feature/*",
      "bugfix": "bugfix/*",
      "hotfix": "hotfix/*",
      "release": "release/*"
    },
    "commit_message_format": {
      "type": ["feat", "fix", "docs", "style", "refactor", "test", "chore"],
      "scope": "optional",
      "template": "<type>(<scope>): <description>"
    },
    "review_requirements": {
      "required_approvals": 1,
      "checks": [
        "lint",
        "test",
        "build",
        "type-check"
      ]
    }
  },
  "code_modification": {
    "file_handling": {
      "verification_rules": [
        {
          "name": "file_existence_check",
          "description": "Before assuming or modifying files",
          "steps": [
            "List and verify all files that will be affected",
            "Check if referenced files actually exist",
            "Never assume existence of files not shown by tools",
            "Document any missing files before proceeding"
          ]
        },
        {
          "name": "minimal_changes",
          "description": "Maintain existing code structure",
          "rules": [
            "Work within existing file structure whenever possible",
            "Create new files only when absolutely necessary",
            "Modify only what is required to complete the task",
            "Preserve existing naming conventions and patterns",
            "Document why new files are necessary when created"
          ]
        }
      ]
    }
  }
}
