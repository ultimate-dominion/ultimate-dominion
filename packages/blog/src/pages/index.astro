---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/layout/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Blog"
  description="Dispatches from the dark — development updates, game design notes, and lore from the world of Ultimate Dominion."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: 'Ultimate Dominion Blog',
    url: 'https://ultimatedominion.com/blog/',
    description: 'Development updates, game design notes, and lore from the world of Ultimate Dominion.',
    publisher: {
      '@type': 'Organization',
      name: 'Ultimate Dominion',
      url: 'https://ultimatedominion.com',
    },
  })} />

  <Header />

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-border">
      <div class="absolute inset-0 bg-gradient-to-b from-accent/5 to-transparent"></div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, transparent 0%, rgba(18,16,14,0.7) 100%);"></div>

      <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 text-center">
        <p class="font-display text-text-secondary text-[11px] tracking-[0.3em] uppercase mb-6">
          Dispatches from the Dark
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-semibold text-parchment mb-5 tracking-tight" style="letter-spacing: 0.06em;">
          Blog
        </h1>
        <p class="text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto font-sans" style="line-height: 1.8;">
          Development updates, game design deep dives, and transmissions from the world of Ultimate Dominion.
        </p>
      </div>
    </section>

    <!-- Posts -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-text-secondary text-lg font-sans italic">The scribes are still writing. Check back soon.</p>
        </div>
      ) : (
        <div class="flex flex-col gap-6">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="blog-card-hover group no-underline block">
              <div class="flex flex-col gap-3">
                <div class="flex items-center gap-3 flex-wrap">
                  <time class="text-xs font-mono text-text-secondary" datetime={post.data.date.toISOString()}>
                    {formatDate(post.data.date)}
                  </time>
                  {post.data.tags.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <h2 class="text-xl sm:text-2xl font-display font-semibold text-parchment group-hover:text-accent transition-colors m-0" style="text-shadow: none; letter-spacing: 0.03em;">
                  {post.data.title}
                </h2>
                <p class="text-text-secondary font-sans m-0 leading-relaxed">
                  {post.data.description}
                </p>
              </div>
            </a>
          ))}
        </div>
      )}
    </section>
  </main>

  <Footer />
</BaseLayout>
