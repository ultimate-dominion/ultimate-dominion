# =============================================================================
# Indexer Environment Configuration
#
# Run one indexer instance per environment. Each needs its own world + DB.
# Copy this file to .env and fill in the values for your target environment.
# =============================================================================

# --- Database ---
DATABASE_URL=postgres://user:password@localhost:5432/ud_indexer

# --- Chain ---
RPC_HTTP_URL=https://base-mainnet.public.blastapi.io
RPC_WS_URL=wss://base-mainnet.blastapi.io/ws
CHAIN_ID=8453

# --- World ---
# Production: 0x99d01939F58B965E6E84a1D167E710Abdf5764b0  (start block: 43183002)
# Beta:       0xD2051EB4F5001d46c11F928BD6578Bd5f7e028A3  (start block: 43005725)
WORLD_ADDRESS=
START_BLOCK=

# --- Server ---
PORT=3001
CORS_ORIGINS=http://localhost:3000

# --- Auth ---
# INDEXER_API_KEY=your_strong_random_key

# --- Captcha (Cloudflare Turnstile) ---
# TURNSTILE_SECRET_KEY=your_turnstile_secret

# --- Session cleanup (private key for submitting cleanup txs) ---
# PRIVATE_KEY=0x...

# --- Monitoring (all optional) ---
# MONITOR_BASE_NODE_URL=
# MONITOR_BASE_NODE_TOKEN=
# MONITOR_BASE_NODE_METRICS_URL=
# MONITOR_ALCHEMY_URL=
# MONITOR_RELAYER_URL=https://8453.relay.ultimatedominion.com/
# MONITOR_CLIENT_PROD_URL=https://ultimatedominion.com
# MONITOR_CLIENT_BETA_URL=https://beta.ultimatedominion.com
# MONITOR_API_URL=
