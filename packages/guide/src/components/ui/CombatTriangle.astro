---
---

<div class="flex justify-center my-8 not-prose">
  <svg viewBox="0 0 300 280" class="w-full max-w-sm" xmlns="http://www.w3.org/2000/svg">
    <!-- Triangle edges -->
    <line x1="150" y1="30" x2="40" y2="240" stroke="#1A244E" stroke-width="2" />
    <line x1="40" y1="240" x2="260" y2="240" stroke="#1A244E" stroke-width="2" />
    <line x1="260" y1="240" x2="150" y2="30" stroke="#1A244E" stroke-width="2" />

    <!-- Arrows showing advantage direction -->
    <!-- STR → AGI (right side, going down) -->
    <line x1="215" y1="120" x2="235" y2="180" stroke="#AF0D08" stroke-width="2" marker-end="url(#arrow-red)" />
    <text x="238" y="155" fill="#AF0D08" font-size="11" font-family="'Fira Code', monospace" text-anchor="start">beats</text>

    <!-- AGI → INT (bottom, going left) -->
    <line x1="210" y1="250" x2="100" y2="250" stroke="#008F07" stroke-width="2" marker-end="url(#arrow-green)" />
    <text x="150" y="270" fill="#008F07" font-size="11" font-family="'Fira Code', monospace" text-anchor="middle">beats</text>

    <!-- INT → STR (left side, going up) -->
    <line x1="65" y1="190" x2="115" y2="80" stroke="#1633B6" stroke-width="2" marker-end="url(#arrow-blue)" />
    <text x="45" y="145" fill="#1633B6" font-size="11" font-family="'Fira Code', monospace" text-anchor="end">beats</text>

    <!-- Arrow markers -->
    <defs>
      <marker id="arrow-red" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#AF0D08" />
      </marker>
      <marker id="arrow-green" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#008F07" />
      </marker>
      <marker id="arrow-blue" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#1633B6" />
      </marker>
    </defs>

    <!-- Stat nodes -->
    <!-- STR (top) -->
    <circle cx="150" cy="30" r="28" fill="#0C1539" stroke="#AF0D08" stroke-width="2" />
    <text x="150" y="27" fill="#AF0D08" font-size="13" font-weight="bold" font-family="Inter, sans-serif" text-anchor="middle">STR</text>
    <text x="150" y="42" fill="#7E848A" font-size="9" font-family="Inter, sans-serif" text-anchor="middle">Warrior</text>

    <!-- INT (bottom left) -->
    <circle cx="40" cy="240" r="28" fill="#0C1539" stroke="#1633B6" stroke-width="2" />
    <text x="40" y="237" fill="#1633B6" font-size="13" font-weight="bold" font-family="Inter, sans-serif" text-anchor="middle">INT</text>
    <text x="40" y="252" fill="#7E848A" font-size="9" font-family="Inter, sans-serif" text-anchor="middle">Mage</text>

    <!-- AGI (bottom right) -->
    <circle cx="260" cy="240" r="28" fill="#0C1539" stroke="#008F07" stroke-width="2" />
    <text x="260" y="237" fill="#008F07" font-size="13" font-weight="bold" font-family="Inter, sans-serif" text-anchor="middle">AGI</text>
    <text x="260" y="252" fill="#7E848A" font-size="9" font-family="Inter, sans-serif" text-anchor="middle">Rogue</text>

    <!-- Center label -->
    <text x="150" y="170" fill="#7E848A" font-size="10" font-family="'Fira Code', monospace" text-anchor="middle">+5% per stat point</text>
  </svg>
</div>
