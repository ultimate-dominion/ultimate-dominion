---
import BaseLayout from './BaseLayout.astro';
import Header from './Header.astro';
import Sidebar from './Sidebar.astro';
import Footer from './Footer.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import TableOfContents from './TableOfContents.astro';
import MobileSidebar from './MobileSidebar.astro';
import SearchModal from '../ui/SearchModal.astro';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface TocItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  breadcrumbs?: BreadcrumbItem[];
  headings?: TocItem[];
  canonical?: string;
  ogImage?: string;
}

const { title, description, breadcrumbs = [], headings = [], canonical, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <slot name="head" slot="head" />

  <Header />
  <MobileSidebar />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Mobile menu button -->
    <button
      id="mobile-menu-trigger"
      class="lg:hidden flex items-center gap-2 text-text-secondary hover:text-parchment mb-4 text-sm"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <span class="font-display tracking-wider uppercase text-xs">Menu</span>
    </button>

    <div class="flex gap-10">
      <Sidebar />

      <main class="flex-1 min-w-0 max-w-4xl">
        {breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} />}

        <article class="prose prose-invert prose-lg max-w-none
          prose-headings:text-parchment prose-headings:font-display
          prose-h1:text-4xl prose-h1:mb-6 prose-h1:mt-0
          prose-h2:text-[1.65rem] prose-h2:mt-14 prose-h2:mb-5
          prose-h3:text-[1.3rem] prose-h3:mt-10 prose-h3:mb-4
          prose-p:text-text-primary prose-p:leading-relaxed prose-p:mb-5
          prose-a:text-accent-gold hover:prose-a:text-accent-glow
          prose-strong:text-parchment
          prose-code:text-accent prose-code:font-mono prose-code:text-sm
          prose-code:bg-surface prose-code:px-1.5 prose-code:py-0.5
          prose-li:text-text-primary prose-li:mb-1.5
          prose-ul:mb-5 prose-ol:mb-5
          prose-table:border-collapse
          prose-th:text-parchment prose-th:text-left prose-th:font-display prose-th:font-semibold prose-th:border-b prose-th:border-border prose-th:px-4 prose-th:py-3
          prose-td:text-text-primary prose-td:border-b prose-td:border-border/50 prose-td:px-4 prose-td:py-3
        " style="--tw-prose-code-bg: #1C1814;">
          <slot />
        </article>
      </main>

      <TableOfContents headings={headings} />
    </div>
  </div>

  <Footer />
  <SearchModal />
</BaseLayout>
