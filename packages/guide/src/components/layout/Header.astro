---
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-border bg-page/95 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo / Home -->
      <a href="/guide/" class="flex items-center gap-3 text-parchment no-underline hover:text-accent transition-colors">
        <span class="text-xl font-display font-semibold tracking-wider">Ultimate Dominion</span>
        <span class="text-[10px] font-mono text-text-secondary border border-border px-2 py-0.5 uppercase tracking-widest" style="border-radius: 2px;">Guide</span>
      </a>

      <!-- Search trigger + CTA -->
      <div class="flex items-center gap-4">
        <button
          id="search-trigger"
          class="flex items-center gap-2 text-text-secondary hover:text-parchment transition-colors text-sm border border-border px-3 py-1.5 hover:border-accent/30"
          style="border-radius: 2px;"
          aria-label="Search guide"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span class="hidden sm:inline font-sans">Search</span>
          <kbd class="hidden sm:inline-block text-xs border border-border px-1.5 py-0.5 text-text-secondary font-mono" style="border-radius: 2px;">Ctrl+K</kbd>
        </button>

        <a
          href="https://ultimatedominion.com"
          class="hidden sm:inline-flex items-center gap-2 torch-button text-sm px-4 py-2"
        >
          Enter
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>
