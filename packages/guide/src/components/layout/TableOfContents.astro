---
interface TocItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: TocItem[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <aside class="hidden xl:block w-56 shrink-0">
    <div class="sticky top-20 overflow-y-auto max-h-[calc(100vh-5rem)] pb-8 pl-4">
      <p class="text-[10px] font-display font-semibold uppercase tracking-[0.2em] text-text-secondary mb-3">On this page</p>
      <ul class="space-y-1 border-l border-border">
        {filteredHeadings.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class:list={[
                'block text-sm no-underline transition-colors py-1 hover:text-accent',
                heading.depth === 2 ? 'pl-4 text-text-secondary' : 'pl-8 text-text-secondary/70',
              ]}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </aside>
)}
