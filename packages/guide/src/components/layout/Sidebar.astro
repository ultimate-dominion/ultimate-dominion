---
import { navigation } from '../../data/navigation';

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/guide/' || href === '/guide') {
    return currentPath === '/guide/' || currentPath === '/guide';
  }
  return currentPath.startsWith(href);
}
---

<nav class="w-64 shrink-0 hidden lg:block">
  <div class="sticky top-20 overflow-y-auto max-h-[calc(100vh-5rem)] pb-8 pr-4">
    <ul class="space-y-1">
      {navigation.map((item) => (
        item.children ? (
          <li class="pt-4 first:pt-0">
            <span class="block text-[10px] font-display font-semibold uppercase tracking-[0.2em] text-text-secondary mb-2 px-3">
              {item.title}
            </span>
            <ul class="space-y-0.5">
              {item.children.map((child) => (
                <li>
                  <a
                    href={child.href}
                    class:list={[
                      'flex items-center gap-2 px-3 py-2 text-sm transition-all no-underline',
                      isActive(child.href)
                        ? 'bg-accent/10 text-accent font-medium border-l-2 border-accent'
                        : 'text-text-primary hover:bg-surface hover:text-parchment',
                    ]}
                    style="border-radius: 2px;"
                  >
                    {child.icon && <span class="text-base w-5 text-center">{child.icon}</span>}
                    <span>{child.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </li>
        ) : item.href !== '#' ? (
          <li>
            <a
              href={item.href}
              class:list={[
                'flex items-center gap-2 px-3 py-2 text-sm font-medium transition-all no-underline',
                isActive(item.href)
                  ? 'bg-accent/10 text-accent border-l-2 border-accent'
                  : 'text-text-primary hover:bg-surface hover:text-parchment',
              ]}
              style="border-radius: 2px;"
            >
              {item.icon && <span class="text-base w-5 text-center">{item.icon}</span>}
              <span>{item.title}</span>
            </a>
          </li>
        ) : null
      ))}
    </ul>
  </div>
</nav>
