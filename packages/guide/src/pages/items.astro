---
import GuideLayout from '../components/layout/GuideLayout.astro';
import DataTable from '../components/ui/DataTable.astro';
import RarityBadge from '../components/ui/RarityBadge.astro';
import Callout from '../components/ui/Callout.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { weapons, armors, consumables, type Rarity } from '../data/items';

const headings = [
  { depth: 2, slug: 'rarity-tiers', text: 'Rarity Tiers' },
  { depth: 2, slug: 'weapons', text: 'Weapons' },
  { depth: 2, slug: 'armor', text: 'Armor' },
  { depth: 2, slug: 'consumables', text: 'Consumables' },
  { depth: 2, slug: 'equipment-requirements', text: 'Equipment Requirements' },
  { depth: 2, slug: 'finding-items', text: 'Finding Items' },
];

function statStr(v: number): string { return v > 0 ? `+${v}` : v < 0 ? `${v}` : '\u2014'; }
---

<GuideLayout
  title="Tools of the Trade"
  description="Complete item guide for Ultimate Dominion. All weapons, armor, consumables, and spells with stats, rarity tiers, and equipment requirements."
  breadcrumbs={[{ label: 'Items' }]}
  headings={headings}
>
  <JsonLd schema={{
    '@type': 'ItemList',
    name: 'Ultimate Dominion Items',
    description: 'All weapons, armor, and consumables in Ultimate Dominion.',
    numberOfItems: weapons.length + armors.length + consumables.length,
    dateModified: '2026-03-27',
  }} slot="head" />

  <h1>Tools of the Trade</h1>
  <p class="text-lg text-text-secondary">
    Ultimate Dominion has three item categories — weapons, armor, and consumables — across five rarity tiers (Worn, Common, Uncommon, Rare, Epic). Weapons are divided into STR, AGI, and INT families. Items account for roughly 60% of a character's total power. All items are on-chain NFTs that can be traded on the player marketplace.
  </p>
  <p class="text-xs text-text-secondary/60 mt-2">Last updated: March 2026</p>

  <h2 id="rarity-tiers">Rarity Tiers</h2>
  <p class="text-sm text-text-secondary mb-2"><em>Five tiers: Worn, Common, Uncommon, Rare, Epic — each progressively more powerful, harder to find, and with higher stat requirements.</em></p>
  <p>Items come in five rarity tiers, each progressively more powerful and harder to find:</p>
  <div class="flex flex-wrap gap-3 my-4 not-prose">
    <RarityBadge rarity="worn" />
    <RarityBadge rarity="common" />
    <RarityBadge rarity="uncommon" />
    <RarityBadge rarity="rare" />
    <RarityBadge rarity="epic" />
  </div>
  <p>
    Higher rarity items have better stats, more stat bonuses, and higher requirements. Epic items are the rarest drops in the cave, with unique on-hit effects.
  </p>

  <h2 id="weapons">Weapons</h2>
  <p class="text-sm text-text-secondary mb-2"><em>Three families: STR (swords/axes/maces), AGI (bows), INT (staves/wands/rods). Many require multiple stats to equip.</em></p>
  <p>
    Weapons determine your base damage and often grant bonus stats. There are three weapon families:
  </p>
  <ul>
    <li><strong>Strength weapons</strong> — swords, axes, maces, hammers. Primary STR requirement.</li>
    <li><strong>Agility weapons</strong> — bows. Primary AGI requirement.</li>
    <li><strong>Intelligence weapons</strong> — staves, wands, rods. Primary INT requirement.</li>
  </ul>

  <Callout type="info" title="Multi-stat requirements">
    Many mid and high-tier weapons require multiple stats to equip (e.g., 11 STR + 4 AGI). This rewards balanced stat allocation and prevents pure glass-cannon builds from accessing the best gear.
  </Callout>

  <DataTable headers={['Name', 'Rarity', 'Damage', 'STR', 'AGI', 'INT', 'HP', 'Requires']}>
    {weapons.map((w) => (
      <tr class="hover:bg-surface/50 transition-colors">
        <td class="px-4 py-2.5 text-white font-medium text-sm">
          {w.name}
          {w.special && <span class="block text-xs text-accent-gold mt-0.5">{w.special}</span>}
        </td>
        <td class="px-4 py-2.5"><RarityBadge rarity={w.rarity} /></td>
        <td class="px-4 py-2.5 font-mono text-sm">{w.damage}</td>
        <td class="px-4 py-2.5 font-mono text-xs text-center">{statStr(w.str)}</td>
        <td class="px-4 py-2.5 font-mono text-xs text-center">{statStr(w.agi)}</td>
        <td class="px-4 py-2.5 font-mono text-xs text-center">{statStr(w.int)}</td>
        <td class="px-4 py-2.5 font-mono text-xs text-center">{statStr(w.hp)}</td>
        <td class="px-4 py-2.5 text-xs text-text-secondary">{w.requires}</td>
      </tr>
    ))}
  </DataTable>

  <h2 id="armor">Armor</h2>
  <p class="text-sm text-text-secondary mb-2"><em>Reduces physical damage per hit, often with bonus stats. No effect on magic damage.</em></p>
  <p>
    Armor reduces incoming physical damage and often provides stat bonuses. Higher armor values mean less damage taken per hit from physical attacks.
  </p>

  <DataTable headers={['Name', 'Rarity', 'Armor', 'STR', 'AGI', 'INT', 'HP', 'Requires']}>
    {armors.map((a) => (
      <tr class="hover:bg-surface/50 transition-colors">
        <td class="px-4 py-2.5 text-white font-medium text-sm">{a.name}</td>
        <td class="px-4 py-2.5"><RarityBadge rarity={a.rarity} /></td>
        <td class="px-4 py-2.5 font-mono text-sm text-center">{a.armor}</td>
        <td class="px-4 py-2.5 font-mono text-xs text-center">{statStr(a.str)}</td>
        <td class="px-4 py-2.5 font-mono text-xs text-center">{statStr(a.agi)}</td>
        <td class="px-4 py-2.5 font-mono text-xs text-center">{statStr(a.int)}</td>
        <td class="px-4 py-2.5 font-mono text-xs text-center">{statStr(a.hp)}</td>
        <td class="px-4 py-2.5 text-xs text-text-secondary">{a.requires}</td>
      </tr>
    ))}
  </DataTable>

  <Callout type="tip" title="Armor is for physical only">
    Armor reduces physical damage but has <strong>no effect on magic</strong>. If you're fighting Mage-class monsters, HP and INT are more valuable than armor. See the <a href="/guide/combat">combat guide</a>.
  </Callout>

  <h2 id="consumables">Consumables</h2>
  <p class="text-sm text-text-secondary mb-2"><em>Single-use items for healing, stat buffs, combat effects, and vendor trash. Dropped by monsters and sold in shops.</em></p>
  <p>
    Consumables are single-use items. Healing and buff consumables are used in combat. Offensive consumables apply debuffs to targets. Junk items have no combat use but can be sold to Tal's Shop for gold.
  </p>

  <DataTable headers={['Name', 'Rarity', 'Effect']}>
    {consumables.map((c) => (
      <tr class="hover:bg-surface/50 transition-colors">
        <td class="px-4 py-2.5 text-white font-medium text-sm">{c.name}</td>
        <td class="px-4 py-2.5"><RarityBadge rarity={c.rarity} /></td>
        <td class="px-4 py-2.5 text-text-primary text-sm">{c.effect}</td>
      </tr>
    ))}
  </DataTable>

  <h2 id="equipment-requirements">Equipment Requirements</h2>
  <p class="text-sm text-text-secondary mb-2"><em>Stat-based only (no level requirements). Many items require multiple stats.</em></p>
  <p>
    Most items above Worn rarity require minimum stat thresholds to equip. Requirements are based on <strong>stats only</strong> — there are no level requirements for items. Many higher-tier items require <strong>multiple stats</strong>, encouraging balanced builds.
  </p>
  <ul>
    <li><strong>STR weapons/armor</strong> — primary Strength requirement, often with secondary AGI or INT.</li>
    <li><strong>AGI weapons/armor</strong> — primary Agility requirement, often with secondary STR or INT.</li>
    <li><strong>INT weapons/armor</strong> — primary Intelligence requirement, often with secondary STR or AGI.</li>
  </ul>

  <h2 id="finding-items">Finding Items</h2>
  <p class="text-sm text-text-secondary mb-2"><em>Monster drops, NPC shops, and the player marketplace — higher-level monsters drop rarer items.</em></p>
  <p>
    Items enter the game through three channels:
  </p>
  <ul>
    <li><strong>Monster drops</strong> — defeat <a href="/guide/bestiary">monsters</a> for a chance at loot. Higher-level creatures drop rarer items. Elite monsters have 2x drop chance.</li>
    <li><strong>Shops</strong> — NPC <a href="/guide/economy">shops</a> sell items at markup prices. Stock is limited and refreshes periodically.</li>
    <li><strong>Marketplace</strong> — buy directly from other players on the <a href="/guide/economy">player marketplace</a>. Prices are set by supply and demand.</li>
  </ul>

  <Callout type="lore">
    The weapons found in the cave were not placed there. They were <em>left</em> — by those who came before, who ventured too deep and never returned. Every blade has a story. Most end in silence.
  </Callout>
</GuideLayout>
