{
  "version": 2,
  "routes": [
    { "src": "/api/uploadMetadata", "dest": "/api/uploadMetadata.ts" },
    { "src": "/api/uploadFile", "dest": "/api/uploadFile.ts" },
    { "src": "/api/session", "dest": "/api/sessionBooting.ts" },
    { "src": "/api/session_lite", "dest": "/api/session_lite.ts" },
    { "src": "/files/(.*)", "dest": "/api/index.ts?file=$1" },
    { "src": "/health", "dest": "/api/health.ts" },
    { "src": "/api/paymasterWebhook", "dest": "/api/paymasterWebhook.ts" },
    { "src": "/api/signup", "dest": "/api/signup.ts" },
    { "src": "/api/drip", "dest": "/api/drip.ts" },
    { "src": "/api/stripe/session", "dest": "/api/stripe/session.ts" },
    { "src": "/api/stripe/webhook", "dest": "/api/stripe/webhook.ts" },
    { "src": "/api/(.*)", "dest": "/api/$1.ts" }
  ],
  "functions": {
    "api/uploadFile.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    { "path": "/api/drip", "schedule": "0 14 * * *" }
  ]
}
