{
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@3.1.7",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/upload", "destination": "/api/uploadMetadata" },
    { "source": "/api/upload-file", "destination": "/api/uploadFile" },
    { "source": "/api/session", "destination": "/api/sessionBooting" },
    { "source": "/api/session_lite", "destination": "/api/session_lite" },
    { "source": "/files/:path*", "destination": "/api/index?file=:path*" },
    { "source": "/health", "destination": "/api/health" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ]
}
