# Client Environment Configuration
#
# Vite loads env files by mode:
#   .env              — Shared vars (all modes: wallet IDs, thirdweb)
#   .env.development  — Local Anvil (chain 31337) — loaded by `vite dev`
#   .env.staging      — Base Mainnet Beta (chain 8453) — loaded by `vite build --mode staging`
#   .env.production   — Base mainnet (chain 8453) — loaded by `vite build`
#
# Vercel builds use dashboard env vars, not these files.
#
# Scripts:
#   pnpm dev            → .env + .env.development (local Anvil)
#   pnpm build:staging  → .env + .env.staging (testnet build)
#   pnpm build          → .env + .env.production (mainnet build)

# --- .env (shared, all modes) ---
VITE_WALLET_CONNECT_PROJECT_ID=your_project_id_here
VITE_THIRDWEB_CLIENT_ID=your_thirdweb_client_id
VITE_BADGE_CONTRACT_ADDRESS=

# --- .env.development (local) ---
# VITE_CHAIN_ID=31337
# VITE_HTTPS_RPC_URL=http://127.0.0.1:8545
# VITE_WS_RPC_URL=ws://127.0.0.1:8545
# VITE_INDEXER_URL=
# VITE_API_URL=http://localhost:3001

# --- .env.staging (beta — Base mainnet, separate world) ---
# VITE_CHAIN_ID=8453
# VITE_HTTPS_RPC_URL=https://base.drpc.org
# VITE_WS_RPC_URL=wss://base.drpc.org
# VITE_WORLD_ADDRESS=0x_your_beta_world_address
# VITE_INDEXER_URL=
# VITE_API_URL=https://ultimate-dominion-api-iota.vercel.app

# --- .env.production (mainnet) ---
# VITE_CHAIN_ID=8453
# VITE_HTTPS_RPC_URL=https://mainnet.base.org
# VITE_WS_RPC_URL=wss://mainnet.base.org
# VITE_INDEXER_URL=
# VITE_API_URL=https://your-mainnet-api.vercel.app
