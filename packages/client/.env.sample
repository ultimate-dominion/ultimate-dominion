# WalletConnect Project ID (Get from https://cloud.walletconnect.com/)
VITE_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# Chain ID (31337 for local Anvil, 11155111 for Sepolia, 1 for Mainnet)
VITE_CHAIN_ID=31337

# Indexer URL (Leave empty for local development)
VITE_INDEXER_URL=

# RPC URLs (Use http://127.0.0.1:8545 for local Anvil)
VITE_HTTPS_RPC_URL=http://127.0.0.1:8545
VITE_WS_RPC_URL=ws://127.0.0.1:8545

# API URL (Use http://localhost:8080 for local development)
VITE_API_URL=http://localhost:8080
