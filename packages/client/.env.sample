# WalletConnect Project ID (Get from https://cloud.walletconnect.com/)
VITE_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# Chain ID (80001 for Pyrope testnet, 31337 for local Anvil)
VITE_CHAIN_ID=80001

# Indexer URL (Leave empty for local development)
VITE_INDEXER_URL=

# RPC URLs
# For Pyrope testnet:
VITE_HTTPS_RPC_URL=https://pyrope-rpc.example.com
VITE_WS_RPC_URL=wss://pyrope-ws.example.com

# For local Anvil (uncomment to use local chain instead of Pyrope):
# VITE_HTTPS_RPC_URL=http://127.0.0.1:8545
# VITE_WS_RPC_URL=ws://127.0.0.1:8545

# API URL (Use http://localhost:3001 for local development)
VITE_API_URL=http://localhost:3001

# Badge Contract Address (for chat gating - set after deployment)
# Leave empty to disable badge gating, or set to badge contract address
VITE_BADGE_CONTRACT_ADDRESS=
