{
  "rewrites": [
    {
      "source": "/s",
      "destination": "/api/share"
    },
    {
      "source": "/api/errors",
      "destination": "/api/errors"
    },
    {
      "source": "/api/metrics",
      "destination": "/api/metrics"
    },
    {
      "source": "/guide",
      "destination": "https://ud-guide.vercel.app/guide"
    },
    {
      "source": "/guide/:path*",
      "destination": "https://ud-guide.vercel.app/guide/:path*"
    },
    {
      "source": "/((?!api|guide|s).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/*.ts": {
      "runtime": "@vercel/node@3.1.7"
    },
    "api/og.tsx": {
      "runtime": "@vercel/edge"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    }
  ]
}
