# Relayer EOA private key(s) — pays gas, submits txs
# Single key (backward compat):
RELAYER_PRIVATE_KEY=0x...
# Multi-key pool (comma-separated, first key is primary for gas charging):
# RELAYER_PRIVATE_KEYS=0xkey1,0xkey2,0xkey3

# RPC endpoint
RPC_URL=https://rpc.ultimatedominion.com
# Bearer token for self-hosted RPC (optional — omit for third-party providers)
# RPC_AUTH_TOKEN=your_long_random_token

# MinimalAccount implementation address (from tw_getDelegationContract)
DELEGATION_CONTRACT=0x...

# Server
PORT=3001
CORS_ORIGINS=http://localhost:3000

# Chain
CHAIN_ID=8453

# World address allowlist — comma-separated, case-insensitive.
# Relayer rejects transactions targeting contracts not in this list.
# Leave empty to allow all targets (dev only — NEVER in production).
ALLOWED_WORLD_ADDRESSES=0xD2051EB4F5001d46c11F928BD6578Bd5f7e028A3

# Gas charging (optional — disabled if WORLD_ADDRESS or GOLD_TOKEN not set)
# WORLD_ADDRESS=0x...
# GOLD_TOKEN=0x...
