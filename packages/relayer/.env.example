# =============================================================================
# Relayer Environment Configuration
#
# Run one relayer instance per environment. Each needs its own keys + world.
# Copy this file to .env and fill in the values for your target environment.
# =============================================================================

# --- Keys ---
# Single key (backward compat):
RELAYER_PRIVATE_KEY=0x...
# Multi-key pool (comma-separated, first key is primary for gas charging):
# RELAYER_PRIVATE_KEYS=0xkey1,0xkey2,0xkey3

# --- RPC ---
RPC_URL=https://base.drpc.org
# Fallback RPC (optional):
# RPC_FALLBACK_URL=https://mainnet.base.org
# Bearer token for self-hosted RPC (optional):
# RPC_AUTH_TOKEN=your_long_random_token

# --- Server ---
PORT=3001
CORS_ORIGINS=http://localhost:3000

# --- Chain ---
CHAIN_ID=8453

# --- Gas funding ---
# TARGET_PLAYER_BALANCE=150000000000000   # 0.00015 ETH — top up to this balance
# MIN_PLAYER_BALANCE=50000000000000       # 0.00005 ETH — trigger top-up below this
# FUNDING_AMOUNT=150000000000000          # legacy alias for TARGET_PLAYER_BALANCE
# MAX_FUNDINGS_PER_MINUTE=10              # Global rate limit

# --- Gas charging (disabled if WORLD_ADDRESS or GOLD_TOKEN not set) ---
# WORLD_ADDRESS=0x...
# GOLD_TOKEN=0x...
# POOL_FEE=10000                          # 1% fee tier (must match deployed pool)

# --- Gold purchase (Stripe → Uniswap ETH→Gold swap) ---
# GOLD_PURCHASE_API_KEY=your_strong_random_key

# --- Fund endpoint auth (required — prevents ETH drain) ---
# FUND_API_KEY=your_strong_random_key

# --- Pool funder (optional deployer wallet that keeps relayer EOAs funded) ---
# FUNDER_PRIVATE_KEY=0x...
# POOL_MIN_BALANCE=5000000000000000       # 0.005 ETH — trigger top-up below this
# POOL_TARGET_BALANCE=10000000000000000   # 0.01 ETH — top up to this balance
# POOL_FUND_CHECK_INTERVAL_MS=300000      # 5 minutes

# --- Persistence ---
# DATA_DIR=./data

# --- Lifeline (level 3+ players stuck with no ETH) ---
# LIFELINE_AMOUNT=300000000000000         # 0.0003 ETH (~5-10 battles)
# LIFELINE_COOLDOWN_MS=86400000           # 24 hours
# LIFELINE_MIN_BALANCE=50000000000000     # 0.00005 ETH — truly stuck threshold
