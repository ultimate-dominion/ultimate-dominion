# =============================================================================
# Relayer Environment Configuration
#
# Run one relayer instance per environment. Each needs its own keys + world.
# Copy this file to .env and fill in the values for your target environment.
# =============================================================================

# --- Keys ---
# Single key (backward compat):
RELAYER_PRIVATE_KEY=0x...
# Multi-key pool (comma-separated, first key is primary for gas charging):
# RELAYER_PRIVATE_KEYS=0xkey1,0xkey2,0xkey3

# --- RPC ---
RPC_URL=https://rpc.ultimatedominion.com
# Fallback RPC (optional):
# RPC_FALLBACK_URL=https://rpc.ultimatedominion.com
# Bearer token for self-hosted RPC (optional):
# RPC_AUTH_TOKEN=your_long_random_token

# --- Server ---
PORT=3001
CORS_ORIGINS=http://localhost:3000

# --- Chain ---
CHAIN_ID=8453

# --- World address allowlist ---
# Comma-separated. Relayer rejects funding for unlisted addresses.
# Leave empty to allow all targets (dev only — NEVER in production).
#
# Production: 0x99d01939F58B965E6E84a1D167E710Abdf5764b0
# Beta:       0xDc34AC3b06fa0ed899696A72B7706369864E5678
ALLOWED_WORLD_ADDRESSES=

# --- Gas funding ---
# FUNDING_AMOUNT=1000000000000000         # 0.001 ETH per funding
# MIN_PLAYER_BALANCE=300000000000000      # 0.0003 ETH — trigger top-up below this
# MAX_FUNDINGS_PER_MINUTE=10              # Global rate limit

# --- Gas charging (disabled if WORLD_ADDRESS or GOLD_TOKEN not set) ---
# WORLD_ADDRESS=0x...
# GOLD_TOKEN=0x...
# POOL_FEE=10000                          # 1% fee tier (must match deployed pool)

# --- Gold purchase (Stripe → Uniswap ETH→Gold swap) ---
# GOLD_PURCHASE_API_KEY=your_strong_random_key

# --- Admin/debug auth (optional) ---
# Used only for detailed health responses. Never expose this to the browser.
# FUND_API_KEY=your_strong_random_key

# --- Embedded wallet funding auth (Privy identity tokens) ---
# Required in production so embedded wallets can authenticate /fund requests.
# Copy your verification key JWK JSON from the Privy dashboard.
# PRIVY_APP_ID=your_privy_app_id
# PRIVY_VERIFICATION_KEY={"crv":"P-256","kty":"EC","x":"...","y":"..."}

# --- Lifeline (level 3+ players stuck with no ETH) ---
# LIFELINE_AMOUNT=300000000000000         # 0.0003 ETH (~5-10 battles)
# LIFELINE_COOLDOWN_MS=86400000           # 24 hours
# LIFELINE_MIN_BALANCE=50000000000000     # 0.00005 ETH — truly stuck threshold
