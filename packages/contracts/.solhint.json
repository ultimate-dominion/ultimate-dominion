{
  "extends": [
    "solhint:recommended",
    "mud"
  ],
  "plugins": [
    "mud"
  ],
  "rules": {
    "compiler-version": [
      "off"
    ],
    "constructor-syntax": "warn",
    "quotes": [
      "error",
      "double"
    ],
    "func-visibility": [
      "warn",
      {
        "ignoreConstructors": true
      }
    ],
    "not-rely-on-time": "off",
    "no-inline-assembly": "off",
    "no-empty-blocks": "off",
    "private-vars-leading-underscore": [
      "warn",
      {
        "strict": false
      }
    ],
    "ordering": "warn",
    "avoid-low-level-calls": "off",
    "max-line-length": [
      "warn",
      120
    ]
  }
}