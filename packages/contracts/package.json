{
  "name": "contracts",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "mud build",
    "clean": "forge clean && rimraf src/codegen",
    "deploy:local": "pnpm run build && DEBUG=mud:* mud deploy --forgeScriptOptions=\"--slow --priority-gas-price=1000000\" --profile=mudFoundry && CHAIN_ID=31337",
    "deploy:testnet-base": "DEBUG=mud:* mud deploy --forgeScriptOptions=\"--slow --priority-gas-price=1000\" --profile=base-sepolia",
    "dev": "pnpm run build && DEBUG=mud:* mud deploy --forgeScriptOptions=\"--slow --priority-gas-price=1000000\" --profile=mudFoundry && CHAIN_ID=31337",
    "lint": "pnpm run prettier && pnpm run solhint",
    "lint:fix": "pnpm run prettier && pnpm lint:sol-tests --fix  && yarn lint:sol-logic --fix",
    "lint:sol-logic": "solhint -c .solhint.json 'src/systems/**/*.sol' 'script/**/*.sol'",
    "lint:sol-tests": "solhint -c .solhint.tests.json 'test/**/*.sol'",
    "prettier": "prettier --write 'src/**/*.sol'",
    "solhint": "solhint --config ./.solhint.json 'src/**/*.sol' --fix",
    "test": "mud build && forge t -vvv --rpc-url http://127.0.0.1:8545"
  },
  "dependencies": {
    "@latticexyz/cli": "2.0.11",
    "@latticexyz/gas-report": "^2.0.12",
    "@latticexyz/schema-type": "2.0.11",
    "@latticexyz/store": "2.0.11",
    "@latticexyz/world": "2.0.11",
    "@latticexyz/world-modules": "2.0.11"
  },
  "devDependencies": {
    "@pythnetwork/entropy-sdk-solidity": "1.3.0",
    "@types/node": "^18.15.11",
    "ds-test": "https://github.com/dapphub/ds-test.git#e282159d5170298eb2455a6c05280ab5a73a4ef0",
    "forge-std": "https://github.com/foundry-rs/forge-std.git#74cfb77e308dd188d2f58864aaf44963ae6b88b1",
    "prettier": "3.2.5",
    "prettier-plugin-solidity": "1.3.1",
    "solhint": "^3.3.7",
    "solhint-config-mud": "2.0.11",
    "solhint-plugin-mud": "2.0.11"
  }
}
