# Ultimate Dominion Windsurf Configuration
# Version: 1.0.0

# Project Information
project:
  name: "Ultimate Dominion"
  description: "Blockchain-based Text MMORPG"
  version: "0.1.0"
  repository: "https://github.com/your-org/ultimate-dominion"

# Code Style Rules
style:
  typescript:
    indent: 2
    quotes: "single"
    semicolons: true
    maxLineLength: 100
    
  solidity:
    indent: 4
    maxLineLength: 120
    orderImports: true

# Auto-formatting Rules
formatting:
  onSave: true
  formatTypes:
    - "*.ts"
    - "*.tsx"
    - "*.sol"
    - "*.md"
    - "*.json"
  ignorePatterns:
    - "node_modules"
    - "dist"
    - ".next"
    - "coverage"

# Command Auto-running
commands:
  safe:
    - "pnpm dev"
    - "pnpm test"
    - "pnpm build"

# Development Quick Start
quickstart:
  instructions: |
    To quickly get started with development:
    1. pnpm install
    2. Copy .env.sample to .env in each package
    3. Replace GARNET_RPC_URL with PYROPE_RPC_URL in config files
    4. Update environment variables in each .env file:
       - For contracts: Set PYROPE_RPC_URL to a valid Pyrope RPC endpoint
       - For client: Set VITE_CHAIN_ID to the Pyrope testnet ID (80001)
       - For API: Set default environment variables
    5. pnpm dev
  
  pyrope:
    rpcEndpoint: "https://pyrope-rpc.example.com"   # Replace with actual Pyrope endpoint
    chainId: 80001                                  # Pyrope testnet chain ID
    blockExplorer: "https://pyrope-explorer.example.com"  # Replace with actual explorer
  
  devEnvironment:
    local:
      - "pnpm dev"         # Starts all services
      - "pnpm dev:client"  # Only frontend
      - "pnpm dev:api"     # Only API server

# Environment Variables Template
# SIMPLIFIED FOR DEVELOPMENT
environment:
  development:
    required:
      - "PYROPE_RPC_URL"     # Use Pyrope testnet RPC instead of Garnet
      - "WALLET_PRIVATE_KEY" # Only for testing contracts
    optional:
      - "MONGODB_URI"        # Uses in-memory DB if not provided
      - "REDIS_URL"          # Uses in-memory cache if not provided
      - "JWT_SECRET"         # Uses default dev secret if not provided
      - "LOG_LEVEL"          # Defaults to 'debug' in development
      - "API_PORT"           # Defaults to 3001
  
  # Full environment requirements for production
  production:
    required:
      - "PYROPE_RPC_URL"     # Use Pyrope testnet
      - "WALLET_PRIVATE_KEY"
      - "MONGODB_URI"
      - "REDIS_URL"
      - "JWT_SECRET"
    optional:
      - "LOG_LEVEL"
      - "API_PORT"

# Git Hooks - Simplified
hooks:
  pre-commit:
    - "pnpm lint"
  pre-push:
    - "pnpm build"

# Documentation Rules - Made Optional for Development
documentation:
  required:
    - "README.md"
  optional:
    - "CONTRIBUTING.md"
    - "CHANGELOG.md"
  components:
    requireJSDoc: false
    requireProps: false
  contracts:
    requireNatSpec: false
  dependencyGraphs:
    enabled: false
    updateOnChange: false

# Documentation Synchronization - Simplified
documentationSync:
  enabled: false
  note: |
    Documentation synchronization is disabled to simplify initial setup.
    Focus on getting the application running before enforcing documentation rules.
  
  trackFiles:
    - "tech_stack.md"
    - "prd.md"
    - "frontend_guidelines.md"
    - "backend_structure.md"
    - "app_flow.md"
    - "smart_contracts_architecture.md"
    - "implementation_plan.md"

  changeRequirements:
    major:
      - updateArchitectureDiagrams: true
      - updateFlowDiagrams: true
      - updateImplementationSteps: true
      - requireChangelogUpdate: true
    
    minor:
      - updateAffectedDocs: true
      - updateImplementationSteps: true
    
    patch:
      - updateAffectedDocs: true

  reviewChecks:
    - checkDocSync: true
    - validateDiagrams: true
    - checkDeadLinks: true
    - ensureConsistency: true

  automation:
    - type: "diagram"
      trigger: "onArchitectureChange"
      action: "updateAsciiDiagrams"
      files: ["*.md"]
    
    - type: "dependency"
      trigger: "onDependencyChange"
      action: "updateTechStack"
      files: ["tech_stack.md"]
    
    - type: "api"
      trigger: "onEndpointChange"
      action: "updateBackendDocs"
      files: ["backend_structure.md"]

  notifications:
    docOutOfSync:
      channels:
        - "slack"
        - "github"
      message: "Documentation update required for recent changes"
    
    missingUpdates:
      checkFrequency: "daily"
      alertThreshold: 3
      notifyTeam: true

# Security Rules
security:
  requireTests: true
  minTestCoverage: 80
  requireAudit: true
  requireTypeChecking: true

# Performance Rules
performance:
  maxBundleSize: "500kb"
  enableTreeShaking: true
  enableCodeSplitting: true

# Dependency Analysis Rules
dependencies:
  analysis:
    enabled: true
    checkOnEdit: true
    checkOnPush: true
    tools:
      - "madge"      # Checks circular dependencies
      - "depcheck"   # Checks unused dependencies
      - "npm-check"  # Checks outdated dependencies
    
  impactAssessment:
    enabled: true
    requireReview: true
    checkLevels:
      - "direct"     # Direct dependencies
      - "indirect"   # Indirect dependencies
      - "circular"   # Circular dependencies
    
  crossPackageChecks:
    enabled: true
    packages:
      - "contracts"
      - "client"
      - "api"
    relationships:
      - from: "contracts"
        to: ["client", "api"]
        requireSync: true
      - from: "api"
        to: ["client"]
        requireSync: true

# Change Impact Rules
changeImpact:
  requireAnalysis: true
  analysisTypes:
    contract:
      - checkAffectedComponents: true
      - checkStateChanges: true
      - checkEventConsumers: true
      - generateImpactReport: true
    
    api:
      - checkConsumers: true
      - checkDataModels: true
      - checkEndpoints: true
      - generateImpactReport: true
    
    frontend:
      - checkPropChanges: true
      - checkStateConsumers: true
      - checkRouteImpact: true
      - generateImpactReport: true
  
  preChangeChecks:
    - type: "typescript"
      command: "pnpm typecheck"
      scope: ["client", "api"]
    
    - type: "contract"
      command: "pnpm test:contracts"
      scope: ["contracts"]
    
    - type: "integration"
      command: "pnpm test:integration"
      scope: ["all"]

# Code Review Rules
review:
  requireImpactAssessment: true
  requireDependencyCheck: true
  requireTestCoverage: true
  requireDocumentation: true
  
  impactThresholds:
    minor:
      maxFiles: 5
      maxDependencies: 3
    major:
      maxFiles: 10
      maxDependencies: 5
    breaking:
      requireRFC: true
      requireTeamReview: true

# Monitoring and Alerts
monitoring:
  dependencyHealth:
    checkFrequency: "daily"
    alertOn:
      - "circular"
      - "unused"
      - "outdated"
    notifyChannels:
      - "slack"
      - "email"

# Example Usage:
# To create a new component:
# windsurf create component MyNewComponent
#
# To create a new contract:
# windsurf create contract MyNewSystem
#
# To create a new service:
# windsurf create service MyNewService
#
# To check impact of changes:
# windsurf check-impact path/to/file
#
# To generate dependency graph:
# windsurf graph-deps [package-name]
#
# To run full impact analysis:
# windsurf analyze-impact
#
# To check documentation sync status:
# windsurf check-docs
#
# To update affected documentation:
# windsurf update-docs
#
# To validate documentation consistency:
# windsurf validate-docs
